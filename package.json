{
  "name": "maestro-croo",
  "version": "1.0.0",
  "description": "Maestro — an autonomous AI agent orchestrator on the CROO Network that hires other agents to compose complete DeFi allocation strategies.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "vercel-build": "echo static",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --test --import tsx/esm test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "author": "Ubong",
  "homepage": "https://github.com/ubongn/maestro-croo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubongn/maestro-croo.git"
  },
  "keywords": [
    "croo",
