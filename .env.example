# ─────────────────────────────────────────────────────────────
# CROO SDK connection
# ─────────────────────────────────────────────────────────────
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
# SDK Key (croo_sk_...) issued from the CROO dashboard after agent registration.
CROO_SDK_KEY=croo_sk_replace_me

# Optional: custom Base RPC for balance pre-checks (defaults to mainnet.base.org)
BASE_RPC_URL=https://mainnet.base.org

# ─────────────────────────────────────────────────────────────
# Maestro's own published service (provider mode)
# This is the serviceId YOUR Maestro agent exposes to users.
# Register it on https://agent.croo.network → Configure → Add Service.
# ─────────────────────────────────────────────────────────────
MAESTRO_SERVICE_ID=

# The user-facing price (USDC) Maestro charges for a full strategy.
MAESTRO_PRICE_USDC=5

# ─────────────────────────────────────────────────────────────
# Target sub-agent service IDs (consumer mode).
# Find these on the CROO store once you have your SDK key, then paste them here.
# Agent IDs are known (below); serviceIds are per-service.
# ─────────────────────────────────────────────────────────────
ALPHATRACK_SERVICE_ID=
POLYMARKET_TRACKER_SERVICE_ID=
HYPERLIQUID_VAULT_SERVICE_ID=
SWAPGOD_SERVICE_ID=

# ─────────────────────────────────────────────────────────────
# LLM (OpenAI-compatible) for strategy synthesis
# ─────────────────────────────────────────────────────────────
LLM_API_KEY=sk-replace_me
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=60000

# ─────────────────────────────────────────────────────────────
# Orchestration tuning
# ─────────────────────────────────────────────────────────────
# Max time to wait for all sub-agent deliveries (ms).
ORCHESTRATION_TIMEOUT_MS=120000
# How many sub-agents to hire per request (>=3 recommended).
MIN_SUB_AGENTS=3
# HTTP server port for the dashboard + API.
PORT=3000
